
public class Program {

    int day, month, year;

    // 🔹 Single function: validation + correction + set
    void setDate(int d, int m, int y) {

        // Fix year
        if (y > 2100) {
            System.out.println("Year too big → setting 2026");
            y = 2026;
        }

        // Fix month
        if (m < 1 || m > 12) {
            System.out.println("Invalid month → setting 1");
            m = 1;
        }

        // Days in month array
        int monthDays[] = {31,28,31,30,31,30,31,31,30,31,30,31};

        // Leap year simple check
        if (m == 2 && y % 4 == 0) {
            monthDays[1] = 29;
        }

        // Fix day
        if (d < 1 || d > monthDays[m - 1]) {
            System.out.println("Invalid day → setting 1");
            d = 1;
        }

        day = d;
        month = m;
        year = y;
    }

    // 🔹 Convert date → total days
    int toTotalDays() {

        int total = year * 365;

        // leap years
        total += year / 4;

        int monthDays[] = {31,28,31,30,31,30,31,31,30,31,30,31};

        // add months
        for (int i = 0; i < month - 1; i++) {
            total += monthDays[i];
        }

        // leap adjustment
        if (month > 2 && year % 4 == 0) {
            total += 1;
        }

        total += day;

        return total;
    }

    // 🔹 Convert total days → date
    void fromTotalDays(int total) {

        year = 0;

        // find year
        while (true) {
            int daysInYear = (year % 4 == 0) ? 366 : 365;

            if (total > daysInYear) {
                total -= daysInYear;
                year++;
            } else {
                break;
            }
        }

        int monthDays[] = {31,28,31,30,31,30,31,31,30,31,30,31};

        month = 1;

        // find month
        for (int i = 0; i < 12; i++) {

            int days = monthDays[i];

            if (i == 1 && year % 4 == 0) {
                days = 29;
            }

            if (total > days) {
                total -= days;
                month++;
            } else {
                break;
            }
        }

        day = total;
    }

    // 🔹 Add days using total days logic
    void addDays(int n) {

        int total = toTotalDays();
        total = total + n;

        fromTotalDays(total);
    }

    // 🔹 Add months (simple logic)
    void addMonths(int n) {

        month = month + n;

        while (month > 12) {
            month = month - 12;
            year++;
        }

        // fix day again (important!)
        setDate(day, month, year);
    }

    // 🔹 Add years
    void addYears(int n) {
        year = year + n;

        // fix date if needed
        setDate(day, month, year);
    }

    // 🔹 Compare using total days (BEST way)
    void compare(int d, int m, int y) {

        int current = toTotalDays();

        // temp conversion
        DateUtil temp = new DateUtil();
        temp.setDate(d, m, y);
        int other = temp.toTotalDays();

        if (current == other)
            System.out.println("Same Date");
        else
            System.out.println("Not Same");
    }

    // 🔹 Display
    void show() {
        System.out.println("Date: " + day + "/" + month + "/" + year);
    }

}
