class Program {

    int day, month, year;

    // 🔹 Leap Year (CORRECT)
    boolean isLeap(int y) {
        return (y % 400 == 0) || (y % 4 == 0 && y % 100 != 0);
    }

    // 🔹 Days in month
    int getDays(int m, int y) {

        if (m == 2)
            return isLeap(y) ? 29 : 28;

        if (m == 4 || m == 6 || m == 9 || m == 11)
            return 30;

        return 31;
    }

    // 🔹 Validation + Correction (ONE METHOD)
    void setDate(int d, int m, int y) {

        if (y > 2100) {
            System.out.println("Year too big → setting 2026");
            y = 2026;
        }

        if (m < 1 || m > 12) {
            System.out.println("Invalid month → setting 1");
            m = 1;
        }

        int max = getDays(m, y);

        if (d < 1 || d > max) {
            System.out.println("Invalid day → setting 1");
            d = 1;
        }

        day = d;
        month = m;
        year = y;
    }

    // 🔹 Convert date → total days (BASE YEAR = 2000)
    int toTotalDays() {

        int total = 0;

        // add days from years
        for (int i = 2000; i < year; i++) {
            total += isLeap(i) ? 366 : 365;
        }

        // add days from months
        for (int i = 1; i < month; i++) {
            total += getDays(i, year);
        }

        // add current day
        total += day;

        return total;
    }

    // 🔹 Convert total days → date (BASE YEAR = 2000)
    void fromTotalDays(int total) {

        year = 2000;

        // find year
        while (true) {

            int daysInYear = isLeap(year) ? 366 : 365;

            if (total > daysInYear) {
                total -= daysInYear;
                year++;
            } else {
                break;
            }
        }

        month = 1;

        // find month
        while (true) {

            int daysInMonth = getDays(month, year);

            if (total > daysInMonth) {
                total -= daysInMonth;
                month++;
            } else {
                break;
            }
        }

        day = total;
    }

    // 🔹 Add days (FIXED)
    void addDays(int n) {

        int total = toTotalDays();
        total += n;

        fromTotalDays(total);
    }

    // 🔹 Add months
    void addMonths(int n) {

        month += n;

        while (month > 12) {
            month -= 12;
            year++;
        }

        setDate(day, month, year);
    }

    // 🔹 Add years
    void addYears(int n) {

        year += n;
        setDate(day, month, year);
    }

    // 🔹 Compare
    void compare(int d, int m, int y) {

        int current = toTotalDays();

        Program temp = new Program();
        temp.setDate(d, m, y);

        int other = temp.toTotalDays();

        if (current == other)
            System.out.println("Same Date");
        else
            System.out.println("Not Same");
    }

    // 🔹 Display
    void show() {
        System.out.println("Date: " + day + "/" + month + "/" + year);
    }
}