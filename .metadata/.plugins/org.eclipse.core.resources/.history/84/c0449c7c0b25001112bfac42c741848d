package calculator;

public class Calculator {

    public static void main(String[] args) {

        Program calc = new Program();
        int choice;

        do {
            System.out.println("\n===== CALCULATOR =====");
            System.out.println("1. Add (int)");
            System.out.println("2. Add (float)");
            System.out.println("3. Add (int + float)");
            System.out.println("4. Subtract");
            System.out.println("5. Multiply");
            System.out.println("6. Divide");
            System.out.println("7. Exit");

            System.out.print("Enter choice: ");
            choice = getInt();

            switch (choice) {

                case 1:
                    System.out.println("Enter two integers:");
                    int a = getInt();
                    int b = getInt();
                    System.out.println("Result: " + calc.add(a, b));
                    break;

                case 2:
                    System.out.println("Enter two floats:");
                    float x = getFloat();
                    float y = getFloat();
                    System.out.println("Result: " + calc.add(x, y));
                    break;

                case 3:
                    System.out.println("Enter int and float:");
                    int i = getInt();
                    float f = getFloat();
                    System.out.println("Result: " + calc.add(i, f));
                    break;

                case 4:
                    System.out.println("Enter two numbers:");
                    float s1 = getFloat();
                    float s2 = getFloat();
                    System.out.println("Result: " + calc.subtract(s1, s2));
                    break;

                case 5:
                    System.out.println("Enter two numbers:");
                    float m1 = getFloat();
                    float m2 = getFloat();
                    System.out.println("Result: " + calc.multiply(m1, m2));
                    break;

                case 6:
                    System.out.println("Enter two numbers:");
                    float d1 = getFloat();
                    float d2 = getFloat();
                    System.out.println("Result: " + calc.divide(d1, d2));
                    break;

                case 7:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 7);
    }

    // ===== FIXED INT INPUT =====
    private static int getInt() {
        try {
            byte[] input = new byte[100];
            int len = System.in.read(input);

            if (len <= 2) {
                System.out.print("Enter valid integer: ");
                return getInt();
            }

            byte[] finalInput = new byte[len - 2];
            System.arraycopy(input, 0, finalInput, 0, len - 2);

            String str = new String(finalInput).trim();

            if (str.isEmpty()) {
                System.out.print("Enter valid integer: ");
                return getInt();
            }

            return Integer.parseInt(str);

        } catch (Exception e) {
            System.out.print("Invalid input! Enter integer again: ");
            return getInt();
        }
    }

    // ===== FIXED FLOAT INPUT =====
    private static float getFloat() {
        try {
            byte[] input = new byte[100];
            int len = System.in.read(input);

            if (len <= 2) {
                System.out.print("Enter valid float: ");
                return getFloat();
            }

            byte[] finalInput = new byte[len - 2];
            System.arraycopy(input, 0, finalInput, 0, len - 2);

            String str = new String(finalInput).trim();

            if (str.isEmpty()) {
                System.out.print("Enter valid float: ");
                return getFloat();
            }

            return Float.parseFloat(str);

        } catch (Exception e) {
            System.out.print("Invalid input! Enter float again: ");
            return getFloat();
        }
    }
}